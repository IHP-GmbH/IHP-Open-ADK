<?xml version="1.0" encoding="UTF-8"?>
<!--
  ADK generic chiplet layer properties. Auto-generated; do not edit by hand.

  Source:    adk/config/chiplet_pads.json
  Generator: adk/klayout/lyp/generate_generic_lyp.py

  Minimal "black-box / pads-only" vocabulary for chiplets from commercial or
  closed PDK nodes whose GDS carries only metal pads + pad names and no .lyp.
  Parsed for layer numbers by gds_to_kicad/lyp_parser.py; styled with KLayout
  built-in patterns so a direct KLayout open shows pads + names + die outline.
-->
<layer-properties>
{% for ly in layers %}
  <properties>
    <frame-color>{{ ly.frame_color }}</frame-color>
    <fill-color>{{ ly.fill_color }}</fill-color>
    <frame-brightness>0</frame-brightness>
    <fill-brightness>0</fill-brightness>
    <dither-pattern>{{ ly.dither }}</dither-pattern>
    <line-style>C0</line-style>
    <valid>true</valid>
    <visible>true</visible>
    <transparent>false</transparent>
    <width>{{ ly.width }}</width>
    <marked>false</marked>
    <animation>0</animation>
    <name>{{ ly.name }}</name>
    <source>{{ ly.source }}</source>
  </properties>
{% endfor %}
</layer-properties>
