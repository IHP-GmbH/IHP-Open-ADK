# Derived from unit_demo.chiplet by chiplet2dbx (ADK); regenerate, do not edit.
Header:
  version: 3
  unit: micron
  precision: 1000
  include:
    - unit_demo.3dbv

Design:
  name: "unit_demo"

ChipletInst:
  interposer:
    reference: SUBSTRATE
  D1:
    reference: DIE_A
  D2:
    reference: DIE_B

Stack:
  interposer:
    loc: [0, 0]
    z: 0
    orient: R0
  D1:
    loc: [100, 200]
    z: 35
    orient: MZ
  D2:
    loc: [600, 200]
    z: 50
    orient: MZ

Connection:
  D1_attach:
    top: D1.regions.front
    bot: interposer.regions.front
    thickness: 25
  D2_attach:
    top: D2.regions.front
    bot: interposer.regions.front
    thickness: 40
  interposer_mount:
    top: interposer.regions.back
    bot: ~
    thickness: 0
